<?xml version="1.0" encoding="utf-8"?>
<talks order="1000">
  <!--万圣夜第1天入场-->
  <group id="halloween_1" tags="mvz2:halloween;mvz2:intro">
    <archive name="万圣夜第1天入场" background="mvz2:misc/eternal_night_swamp" music="mvz2:mainmenu">
      <unlock>
        <condition required="mvz2:level.halloween_1" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>到终点了！就这儿！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short1">
          <text>……幻想乡入口呢？</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long1">
          <text>反正一定能找到的，我以我的胡子起誓！</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>顺便，这里也有那些僵尸啊。</text>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>出于我的一片好心，你就把他们清理了吧！</text>
        </sentence>
        <!--语句5-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short3">
          <text>哦对了，顺带一提：</text>
        </sentence>
        <!--语句6-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_extra_long3">
          <text>我们的矿场是以太阳能工作的，而现在是晚上。</text>
        </sentence>
        <!--语句7-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream2">
          <text>所以，它现在没法被使用了！</text>
        </sentence>
        <!--语句8-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>靠着你的熔炉活过今晚吧！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第1天结束-->
  <group id="halloween_1_over" tags="mvz2:halloween;mvz2:over">
    <archive name="万圣夜第1天结束" background="mvz2:misc/eternal_night_swamp">
      <unlock>
        <condition required="mvz2:level.halloween_1" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>这位是我们的老朋友，小型发射器！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short1">
          <text>和我们的小伙伴打个招呼吧！</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long1">
          <text>小型发射器不需要能量就能放置，能够喷射短距离的雪球，是夜晚的一大利器！</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream1">
          <text>好好利用吧！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>bubble hide</script>
            <script>character create mvz2:orant right</script>
            <script>delay 0.5</script>
            <script>next</script>
          </onClick>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:orant" description="（欧兰特出场）" sounds="mvz2:talk">
          <text>……你们是？</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第1天地图-->
  <group id="halloween_1_map" tags="mvz2:halloween;mvz2:map">
    <archive name="万圣夜第1天地图" background="mvz2:misc/eternal_night_swamp" music="mvz2:halloween_map">
      <unlock>
        <condition required="mvz2:level.halloween_1" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
        <character id="mvz2:orant" side="right" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream2">
          <text>哇！野生的女巫出现了！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>啊？好像不是……</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>请问一下，你们是什么人，怎么到这里来的？</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>我们就是专门清理这些僵尸的人，顺着一个藏宝图来的！</text>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>……这样啊，我明白了。</text>
        </sentence>
        <!--语句5-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>那个，如果可以的话，能不能帮我一个忙？</text>
        </sentence>
        <!--语句6-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>就是……这里的僵尸和死者，都开始复活了起来，能不能帮我……让他们安息？</text>
        </sentence>
        <!--语句7-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream1">
          <text>没问题！交给我坑爹村民——的伙计，史蒂夫吧！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--星之碎片教程-->
  <group id="starshard_tutorial" tags="mvz2:halloween;mvz2:tutorial">
    <archive name="星之碎片教程" background="mvz2:misc/eternal_night_swamp" music="mvz2:mainmenu">
      <unlock>
        <condition required="mvz2:starshard" />
      </unlock>
    </archive>
    <!--开始段落-->
    <section>
      <!--分段开始脚本-->
      <onStart>
        <script>action prepare_starshard_tutorial</script>
      </onStart>
      <!--分段自动跳过脚本-->
      <onAutoSkip>
        <script>action prepare_starshard_tutorial</script>
        <script>action start_starshard_tutorial</script>
      </onAutoSkip>
      <!--分段跳过脚本-->
      <onSkip>
        <script>action start_starshard_tutorial</script>
        <script>end</script>
      </onSkip>
      <!--对话档案文本-->
      <text>开始段落</text>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>嘿，伙计，我来给你分享一些神奇的事情！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long1">
          <text>这个东西叫做星之碎片！它能随着当前地方变形成一种道具！</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>但是，它的效果都是一样的！都能让你的器械爆发！</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream1">
          <text>好了，现在来试试吧！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>action start_starshard_tutorial</script>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
    <!--教程完成后-->
    <section>
      <!--对话档案文本-->
      <text>教程完成后</text>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream1">
          <text>干得不错！伙计！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>噢！天哪！看起来又有一大批客人来要我们招待了！</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_crazy">
          <text>一起来吧！我——坑爹了！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第2天结束-->
  <group id="halloween_2_over" tags="mvz2:halloween;mvz2:over">
    <archive name="万圣夜第2天结束" background="mvz2:misc/eternal_night_swamp">
      <unlock>
        <condition required="mvz2:level.halloween_2" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>嘿！这是月光传感器！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>它能依靠月光或黑暗，自动为你增加能量！而且一段时间后会提高生产量！</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream1">
          <text>因为它的廉价，用它来代替熔炉吧！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第2天地图-->
  <group id="halloween_2_map" tags="mvz2:halloween;mvz2:map">
    <archive name="万圣夜第2天地图" background="mvz2:misc/eternal_night_swamp" music="mvz2:halloween_map">
      <unlock>
        <condition required="mvz2:level.halloween_2" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
        <character id="mvz2:orant" side="right" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>你们看起来……的确是有一手。</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>对了，我好像还没有自我介绍。</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>我是欧兰特，是一位灵魂术士，在这里……等候一些人的到来。</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>不会是在等我们吧？</text>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk" variant="mvz2:close_eye">
          <text>……抱歉，我不能说。</text>
        </sentence>
        <!--语句5-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>啊，好吧。</text>
        </sentence>
        <!--语句6-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long1">
          <text>您是一位灵魂术士，那您知道这些僵尸为什么会复活吗？</text>
        </sentence>
        <!--语句7-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk" variant="mvz2:normal">
          <text>我不太清楚。自从一段时间前开始，这些僵尸和骷髅就开始出现了。</text>
        </sentence>
        <!--语句8-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>不止如此，还有一些更加危险的怪物藏在这里，请务必小心。</text>
        </sentence>
        <!--语句9-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:talk">
          <text>看来我们得好好招待这些万圣节的客人了！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第3天入场-->
  <group id="halloween_3" tags="mvz2:halloween;mvz2:intro">
    <archive name="万圣夜第3天入场" background="mvz2:misc/eternal_night_swamp" music="mvz2:mainmenu">
      <unlock>
        <condition required="mvz2:level.halloween_3" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
        <character id="mvz2:orant" side="right" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>话说回来，那些雕像是什么啊？</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>那些石像啊……好像是叫石像鬼。</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>具体的信息我不是很清楚了，需要看看图鉴。</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>……说起来，我的图鉴呢？</text>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk" variant="mvz2:close_eye">
          <text>……对啊，图鉴……</text>
        </sentence>
        <!--语句5-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short3">
          <text>好吧，看来今天我们是没法得知这些东西是什么了。</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第3天结束-->
  <group id="halloween_3_over" tags="mvz2:halloween;mvz2:over">
    <archive name="万圣夜第3天结束" background="mvz2:misc/eternal_night_swamp">
      <unlock>
        <condition required="mvz2:level.halloween_3" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>这个是荧石，可以照亮并驱散周围的浓雾！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long2">
          <text>不过……这月光照耀的地方哪来的雾啊……</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short3">
          <text>那它是用来干什么的呢？</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第3天地图-->
  <group id="halloween_3_map" tags="mvz2:halloween;mvz2:map">
    <archive name="万圣夜第3天地图" background="mvz2:misc/eternal_night_swamp" music="mvz2:halloween_map">
      <unlock>
        <condition required="mvz2:level.halloween_3" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
        <character id="mvz2:orant" side="right" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>看来……嗯，图鉴是弄丢了。</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>大概是和那些怪物战斗的时候弄丢的吧。</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short3">
          <text>嗯……那还真是不幸。</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>不过不必担心，那些僵尸大概也会把图鉴带回来的吧。</text>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk" variant="mvz2:close_eye">
          <text>因为——嗯……他们会拿着他们遇到的……一些东西。</text>
        </sentence>
        <!--语句5-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk" variant="mvz2:normal">
          <text>大概，他们也会把我的图鉴带来吧。</text>
        </sentence>
        <!--语句6-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_scream1">
          <text>是吗？那么我们也来帮忙找找吧！</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第4天入场-->
  <group id="halloween_4" tags="mvz2:halloween;mvz2:intro">
    <archive name="万圣夜第4天入场" background="mvz2:misc/eternal_night_swamp" music="mvz2:mainmenu">
      <unlock>
        <condition required="mvz2:level.halloween_4" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
        <character id="mvz2:orant" side="right" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>你们之前拿到的东西是荧石吧？</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>来源于下界的发光石头，人间的确不多见。</text>
        </sentence>
        <!--语句2-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long1">
          <text>它只会发光，可是这里好像没什么需要照亮的东西。</text>
        </sentence>
        <!--语句3-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>也许……</text>
        </sentence>
        <!--语句4-->
        <sentence speaker="mvz2:orant" sounds="mvz2:talk">
          <text>幽灵要开始游荡了。</text>
          <!--语句点击脚本-->
          <onClick>
            <script>end</script>
          </onClick>
        </sentence>
      </sentences>
    </section>
  </group>
  <!--万圣夜第4天结束-->
  <group id="halloween_4_over" tags="mvz2:halloween;mvz2:over">
    <archive name="万圣夜第4天结束" background="mvz2:misc/eternal_night_swamp">
      <unlock>
        <condition required="mvz2:level.halloween_4" />
      </unlock>
    </archive>
    <section>
      <!--角色列表-->
      <characters>
        <character id="mvz2:crazy_villager" side="left" />
      </characters>
      <!--语句列表-->
      <sentences>
        <!--语句0-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_short2">
          <text>这个是冲击活塞！</text>
        </sentence>
        <!--语句1-->
        <sentence speaker="mvz2:crazy_villager" sounds="mvz2:villager_long3">
          <text>它能够击退前方的怪物一大格距离！并且重创脆弱的石头或者其他东西！</text>
        </sentence>
